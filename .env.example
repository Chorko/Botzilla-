# ═══════════════════════════════════════════════
# BOTZILLA — Environment Variables
# Copy this to .env and fill in your keys
# ═══════════════════════════════════════════════

# ── LLM API Keys ──
# Primary: Gemini 2.5 Flash for Cleaner + Summary calls
GEMINI_API_KEY=""

# Optional: Groq kept only for fallback audio transcription routing
GROQ_API_KEY=""

# ── HuggingFace (for WhisperX + pyannote) ──
# Accept licenses at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=""

# ── Supabase ──
SUPABASE_URL=""
SUPABASE_KEY=""
SUPABASE_ANON_KEY=""

# ── LLM Config ──
# Options for WHISPER_MODEL: tiny, base, small, medium, large-v3
WHISPER_MODEL="large-v3"
LANGUAGE="en"

# ── Chatbot Confidence Threshold ──
# Below this, chatbot escalates to Gemini API (0.0 - 1.0)
CHATBOT_CONFIDENCE_FALLBACK_THRESHOLD="0.75"
